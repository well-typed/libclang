#ifndef LIBCLANG_VERSION_H
#define LIBCLANG_VERSION_H

#define LIBCLANG_VERSION_MAJOR @LIBCLANG_VERSION_MAJOR@
#define LIBCLANG_VERSION_MINOR @LIBCLANG_VERSION_MINOR@
#define LIBCLANG_VERSION_PATCH @LIBCLANG_VERSION_PATCH@

#define MIN_VERSION_LIBCLANG(major,minor,patch) ( \
  (major)*10000+(minor)*100+(patch) <= \
    (LIBCLANG_VERSION_MAJOR)*10000+(LIBCLANG_VERSION_MINOR)*100+(LIBCLANG_VERSION_PATCH))

#endif // LIBCLANG_VERSION_H
